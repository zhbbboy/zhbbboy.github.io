---
import type { PostFolder } from '@/lib/posts';
import { formatDate } from '@/lib/posts';
import PostFolderItem from './post-folder.astro';

interface Props {
  folder: PostFolder;
  depth?: number;
  open?: boolean;
}

const { folder, depth = 0, open = depth < 2 } = Astro.props;
const base = import.meta.env.BASE_URL;
const postBase = `${base.endsWith('/') ? base.slice(0, -1) : base}/posts`;
const hasChildren = folder.folders.length > 0 || folder.posts.length > 0;
---

<li class="tree-folder">
  <details class="group" open={open}>
    <summary class="tree-summary" aria-label={`展开或收起 ${folder.name}`}>
      <svg class="tree-chevron" viewBox="0 0 16 16" aria-hidden="true">
        <path d="m6 3 5 5-5 5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" />
      </svg>
      <svg class="tree-folder-icon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M3.5 6.75A2.25 2.25 0 0 1 5.75 4.5h4.1l2 2h6.4a2.25 2.25 0 0 1 2.25 2.25v8.5a2.25 2.25 0 0 1-2.25 2.25H5.75a2.25 2.25 0 0 1-2.25-2.25v-10.5Z" fill="currentColor" opacity=".18" />
        <path d="M3.5 8.75A2.25 2.25 0 0 1 5.75 6.5h4.1l2 2h6.4a2.25 2.25 0 0 1 2.25 2.25v8.5a2.25 2.25 0 0 1-2.25 2.25H5.75a2.25 2.25 0 0 1-2.25-2.25v-8.5Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.5" />
      </svg>
      <span class="min-w-0 truncate">{folder.name}</span>
      <span class="tree-count">{folder.postCount}</span>
    </summary>

    {hasChildren && (
      <div class="tree-children">
        <ul role="list">
          {folder.folders.map((child) => (
            <PostFolderItem folder={child} depth={depth + 1} open={depth < 1} />
          ))}
          {folder.posts.map((post) => (
            <li class="tree-post">
              <svg class="tree-file-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M6.75 3.75h6.5l4 4v12.5H6.75A1.75 1.75 0 0 1 5 18.5v-13A1.75 1.75 0 0 1 6.75 3.75Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.5" />
                <path d="M13.25 3.75v4h4" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.5" />
              </svg>
              <a href={`${postBase}/${post.id}`} class="tree-post-link">{post.data.title}</a>
              <time datetime={post.data.date.toISOString()} class="tree-date">{formatDate(post.data.date)}</time>
            </li>
          ))}
        </ul>
      </div>
    )}
  </details>
</li>
