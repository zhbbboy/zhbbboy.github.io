---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const items = headings.filter((h) => h.depth >= 2 && h.depth <= 4);
---
{items.length > 0 && (
  <nav aria-label="目录" class="text-sm">
    <p class="font-semibold mb-2 text-zinc-700 dark:text-zinc-200">目录</p>
    <ul class="space-y-1.5 border-l border-zinc-200 dark:border-zinc-800 pl-3">
      {items.map((h) => (
        <li style={`padding-left: ${(h.depth - 2) * 0.75}rem`}>
          <a
            href={`#${h.slug}`}
            class="text-zinc-600 dark:text-zinc-400 hover:text-sky-600 dark:hover:text-sky-400"
          >{h.text}</a>
        </li>
      ))}
    </ul>
  </nav>
)}
