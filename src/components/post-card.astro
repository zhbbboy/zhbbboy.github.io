---
import type { Post } from '@/lib/posts';
import { formatDate } from '@/lib/posts';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const base = import.meta.env.BASE_URL;
const href = `${base.endsWith('/') ? base.slice(0, -1) : base}/posts/${post.id}`;
const tagBase = `${base.endsWith('/') ? base.slice(0, -1) : base}/tags`;
---
<article class="py-5 border-b border-zinc-200 dark:border-zinc-800 last:border-b-0">
  <h2 class="text-xl font-semibold mb-1">
    <a href={href} class="hover:text-sky-600 dark:hover:text-sky-400">{post.data.title}</a>
  </h2>
  <div class="text-xs text-zinc-500 dark:text-zinc-400 flex flex-wrap items-center gap-x-3 gap-y-1">
    <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
    {post.data.tags.length > 0 && (
      <span class="flex flex-wrap gap-1.5">
        {post.data.tags.map((t) => (
          <a
            href={`${tagBase}/${encodeURIComponent(t)}`}
            class="px-1.5 py-0.5 rounded bg-zinc-100 dark:bg-zinc-800 hover:bg-sky-100 dark:hover:bg-sky-900"
          >#{t}</a>
        ))}
      </span>
    )}
  </div>
  {post.data.description && (
    <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-300">{post.data.description}</p>
  )}
</article>
