---
import BaseLayout from '@/layouts/base-layout.astro';
import { getPublishedPosts, collectTags } from '@/lib/posts';

const posts = await getPublishedPosts();
const tags = [...collectTags(posts).entries()].sort((a, b) => b[1] - a[1]);
const base = import.meta.env.BASE_URL;
const tagBase = `${base.endsWith('/') ? base.slice(0, -1) : base}/tags`;

function sizeClass(count: number): string {
  if (count >= 5) return 'text-2xl';
  if (count >= 3) return 'text-xl';
  if (count >= 2) return 'text-lg';
  return 'text-base';
}
---
<BaseLayout title="标签">
  <h1 class="text-2xl font-bold mb-4">标签云</h1>
  {tags.length === 0 ? (
    <p class="text-zinc-500">还没有标签。</p>
  ) : (
    <div class="flex flex-wrap items-baseline gap-x-4 gap-y-2">
      {tags.map(([tag, count]) => (
        <a
          href={`${tagBase}/${encodeURIComponent(tag)}`}
          class={`${sizeClass(count)} hover:text-sky-600 dark:hover:text-sky-400`}
        >
          #{tag}<span class="text-xs text-zinc-500 dark:text-zinc-400 ml-1">{count}</span>
        </a>
      ))}
    </div>
  )}
</BaseLayout>
