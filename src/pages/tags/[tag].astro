---
import BaseLayout from '@/layouts/base-layout.astro';
import PostCard from '@/components/post-card.astro';
import { getPublishedPosts, collectTags, type Post } from '@/lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = [...collectTags(posts).keys()];
  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.filter((p) => p.data.tags.includes(tag)),
    },
  }));
}

interface Props {
  tag: string;
  posts: Post[];
}

const { tag, posts } = Astro.props;
---
<BaseLayout title={`#${tag}`}>
  <h1 class="text-2xl font-bold mb-1">#{tag}</h1>
  <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-4">{posts.length} 篇笔记</p>
  <div>
    {posts.map((post) => <PostCard post={post} />)}
  </div>
</BaseLayout>
