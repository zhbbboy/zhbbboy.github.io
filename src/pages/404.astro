---
import BaseLayout from '@/layouts/base-layout.astro';
const base = import.meta.env.BASE_URL;
---
<BaseLayout title="404">
  <h1 class="text-3xl font-bold mb-2">404</h1>
  <p class="text-zinc-500 mb-4">页面不存在。</p>
  <a href={base} class="text-sky-600 dark:text-sky-400 hover:underline">回到首页</a>
</BaseLayout>
