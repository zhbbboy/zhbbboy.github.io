---
import BaseLayout from '@/layouts/base-layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pagefindUI = `${base}/pagefind/pagefind-ui.js`;
const pagefindCss = `${base}/pagefind/pagefind-ui.css`;
---
<BaseLayout title="搜索">
  <h1 class="text-2xl font-bold mb-4">搜索</h1>
  <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-4">
    索引由 Pagefind 在构建时生成。开发模式（<code>astro dev</code>）下不可用，请先运行 <code>npm run build</code> 再 <code>npm run preview</code>。
  </p>
  <div id="search"></div>

  <link rel="stylesheet" href={pagefindCss} />
  <script is:inline define:vars={{ pagefindUI }}>
    window.addEventListener('DOMContentLoaded', async () => {
      try {
        const mod = await import(pagefindUI);
        new mod.PagefindUI({
          element: '#search',
          showSubResults: true,
          resetStyles: false,
        });
      } catch (err) {
        const el = document.getElementById('search');
        if (el) el.textContent = '搜索索引尚未生成，请先执行 npm run build。';
      }
    });
  </script>
</BaseLayout>
