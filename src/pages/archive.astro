---
import BaseLayout from '@/layouts/base-layout.astro';
import PostFolder from '@/components/post-folder.astro';
import { buildPostFolderTree, getPostFolderSegments, getPublishedPosts } from '@/lib/posts';

const posts = await getPublishedPosts();
const folders = buildPostFolderTree(posts);
const rootPosts = posts.filter((post) => getPostFolderSegments(post).length === 0);
---

<BaseLayout title="文章目录" description="按文件夹浏览所有文章">
  <section class="max-w-4xl">
    <div class="mb-7">
      <p class="text-sm font-medium text-sky-700 dark:text-sky-400 mb-2">KNOWLEDGE BASE</p>
      <h1 class="text-3xl font-bold tracking-tight">文章目录</h1>
      <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-300">
        按文章文件夹浏览，共 {posts.length} 篇。点击文件夹名称即可展开或收起。
      </p>
    </div>

    {posts.length === 0 ? (
      <p class="text-zinc-500">还没有发布的文章。</p>
    ) : (
      <div class="post-tree rounded-xl border border-zinc-200 bg-white px-3 py-3 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/30 sm:px-4">
        <ul role="list">
          {folders.map((folder) => <PostFolder folder={folder} open={true} />)}
          {rootPosts.length > 0 && (
            <li class="tree-root-posts">
              <p class="tree-root-title">未分类文章</p>
              <ul role="list">
                {rootPosts.map((post) => (
                  <li class="tree-post">
                    <svg class="tree-file-icon" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M6.75 3.75h6.5l4 4v12.5H6.75A1.75 1.75 0 0 1 5 18.5v-13A1.75 1.75 0 0 1 6.75 3.75Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.5" />
                      <path d="M13.25 3.75v4h4" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.5" />
                    </svg>
                    <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/posts/${post.id}`} class="tree-post-link">{post.data.title}</a>
                  </li>
                ))}
              </ul>
            </li>
          )}
        </ul>
      </div>
    )}
  </section>
</BaseLayout>
