---
import BaseLayout from '@/layouts/base-layout.astro';
import { getPublishedPosts, groupByYear, formatDate } from '@/lib/posts';

const posts = await getPublishedPosts();
const grouped = [...groupByYear(posts).entries()].sort((a, b) => b[0] - a[0]);
const base = import.meta.env.BASE_URL;
const postBase = `${base.endsWith('/') ? base.slice(0, -1) : base}/posts`;
---
<BaseLayout title="归档">
  <h1 class="text-2xl font-bold mb-6">归档</h1>
  {grouped.length === 0 ? (
    <p class="text-zinc-500">还没有笔记。</p>
  ) : (
    <div class="space-y-8">
      {grouped.map(([year, items]) => (
        <section>
          <h2 class="text-xl font-semibold border-b border-zinc-200 dark:border-zinc-800 pb-1 mb-3">{year}</h2>
          <ul class="space-y-2">
            {items.map((post) => (
              <li class="flex gap-4 items-baseline">
                <time class="text-sm font-mono text-zinc-500 dark:text-zinc-400 w-24 shrink-0">
                  {formatDate(post.data.date)}
                </time>
                <a
                  href={`${postBase}/${post.id}`}
                  class="hover:text-sky-600 dark:hover:text-sky-400"
                >{post.data.title}</a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  )}
</BaseLayout>
